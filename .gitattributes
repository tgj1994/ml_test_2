# Force LF for files that will be executed/parsed on Linux.
# Without this, Windows clients commit CRLF and `#!/usr/bin/env bash\r`
# breaks start.sh on the server.

*.sh        text eol=lf
*.py        text eol=lf
*.md        text eol=lf
*.toml      text eol=lf
*.json      text eol=lf
*.lock      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf
.python-version text eol=lf

# Binary — never touch
*.parquet   binary
*.png       binary
*.csv       text
